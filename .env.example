# Docker Compose 环境变量示例
# 复制为 .env 并填写真实值后使用

# ========== PostgreSQL ==========
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wechat_editor
POSTGRES_PORT=5432

# ========== Redis ==========
REDIS_PASSWORD=
REDIS_PORT=6379

# ========== 后端 API ==========
API_PORT=8000

# ========== 前端 ==========
FRONTEND_PORT=80

# ========== Nginx（统一入口，可选）==========
NGINX_HTTP_PORT=8080
